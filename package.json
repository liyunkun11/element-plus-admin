{
  "name": "element-plus-admin",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "svgo:simple": "svgo -f src/icons/simple --config=src/icons/simple.config.cjs",
    "svgo:complex": "svgo -f src/icons/complex --config=src/icons/complex.config.cjs"
  },
  "dependencies": {
    "@vueuse/core": "^10.10.0",
    "axios": "^1.7.2",
    "color": "^5.0.3",
    "dayjs": "^1.11.11",
    "echarts": "^5.5.0",
    "element-plus": "^2.13.3",
    "lodash-es": "^4.17.21",
    "normalize.css": "^8.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.29",
    "vue-echarts": "^6.7.2",
    "vue-router": "^4.3.2",
    "vxe-table": "~4.18.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.20.0",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.14.0",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^5.0.4",
    "eslint": "^8.57.0",
    "eslint-plugin-format": "^0.1.1",
    "husky": "^9.0.11",
    "less": "^4.2.0",
    "lint-staged": "^15.2.5",
    "svgo": "^3.3.2",
    "typescript": "^5.2.2",
    "unplugin-vue-components": "^0.27.0",
    "vite": "^5.2.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue-tsc": "^2.0.6"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix"
    ]
  }
}
